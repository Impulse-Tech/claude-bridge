# claude-bridge configuration (copy to .env and edit, or set in your service unit)

# HTTP listen port.
PORT=9180

# Path to the claude CLI binary. Leave unset to auto-detect.
# CLAUDE_BIN=/home/you/.local/bin/claude

# Default model alias when the client doesn't specify one.
# Valid: sonnet | opus | haiku | claude-sonnet-4-6 | claude-opus-4-7 | claude-haiku-4-5
DEFAULT_MODEL=sonnet

# Directories Claude is allowed to read via --add-dir (colon-separated).
# Without this, Claude can only read its CWD.
# CLAUDE_ALLOWED_DIRS=/home/you/Documents:/home/you/projects

# Or skip the per-directory permission system entirely.
# Use only on trusted personal machines — gives Claude full filesystem access
# as your user. Bridge is localhost-only by default so non-local actors
# can't trigger anything, but any local process can.
# CLAUDE_BYPASS_PERMISSIONS=true
